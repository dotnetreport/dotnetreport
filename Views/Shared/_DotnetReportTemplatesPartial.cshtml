                    <pre><code data-bind="html: ReportSql" style="white-space: pre-wrap;"></code></pre>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal" id="sqlDrillDownModal" tabindex="-1" role="dialog" aria-hidden="true">
