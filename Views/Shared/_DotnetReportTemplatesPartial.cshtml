                <i class="fa fa-bars sortable me-2" style="cursor:move;"></i>
                <span data-bind="text: name"></span>
            </span>
            <button type="button" class="btn btn-sm btn-outline-danger"
                    data-bind="click: $parent.removeSubReport">
                Delete
