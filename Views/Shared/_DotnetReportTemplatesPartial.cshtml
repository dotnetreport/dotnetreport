        <div class="col-md-4">
        <select class="form-select" data-bind="options: SelectedFields, value: SelectFieldToInsert, optionsCaption: 'Select a field...', optionsText: 'selectedFieldName'"></select>
        </div>
        <div class="col-auto dropdown">
            <button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown">
            <i class="fa fa-table"></i> Insert as Table
            </button>
            <ul class="dropdown-menu">
                <li><a class="dropdown-item" href="#" data-bind="click: insertFieldTableTransposed">Transposed</a></li>
                <li><a class="dropdown-item" href="#" data-bind="click: insertFieldTableStandard">Standard</a></li>
