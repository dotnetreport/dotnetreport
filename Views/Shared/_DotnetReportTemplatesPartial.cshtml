<script type="text/html" id="custom-function-designer">

    <div class="row">
        <div class="col-md-12" data-bind="visible: isFunctionField()">
            <div class="alert alert-info">
                You are now creating a Customized Field using Functions available.
            </div>
        </div>
    </div>

    <div class="form-group row">
        <label class="col-sm-2 control-label">Field Label</label>
        <div class="col-sm-10">
            <input type="text" class="form-control form-control-sm" data-bind="value: formulaFieldLabel" required placeholder="Custom Field Label" />
        </div>
    </div>
    <div class="form-group row">
        <label class="col-sm-2 control-label">Data Format</label>
        <div class="col-sm-10">
            <select class="form-select form-control-sm" data-bind="value: formulaDataFormat" required>
                <option>String</option>
                <option>Integer</option>
                <option>Decimal</option>
                <option>Currency</option>
                <option>Date</option>
                <option value="DateTime">Date and Time</option>
            </select>
        </div>
    </div>
    <div class="form-group row" data-bind="visible: formulaDataFormat() == 'Decimal' || formulaDataFormat() == 'Currency'">
        <label class="col-sm-2 control-label">Round to Decimal Places</label>
        <div class="col-sm-10">
            <input type="number" class="form-control" data-bind="value: formulaDecimalPlaces" placeholder="Choose Decimal places (leave blank to not use rounding)" title="Choose Decimal places (leave blank to not use rounding)" />
        </div>
    </div>

    <div>
        Define your Function:
        <textarea id="function-code"></textarea>
    </div>
    <div class="form-group row" >
        <div class="col-md-12 pull-right">
            <hr />
            <a href="#" class="btn btn-primary btn-sm" title="Save Custom Function Field" data-bind="click: saveFunctionField, visible: isFunctionField">Save</a>
            <a href="#" class="btn btn-sm" title="Custom Field using Function" data-bind="click: function(){isFunctionField(!isFunctionField())}, text: isFunctionField() ? 'Cancel': 'Function', css: {'btn-primary': !isFunctionField(), 'btn-danger': isFunctionField}"></a>
        </div>
    </div>
</script>

<script type="text/html" id="custom-field-designer">
    <div>
        <div class="row">
            <div class="col-md-12" data-bind="visible: isFormulaField()">
                <div class="alert alert-info">
                    You are now creating a Customized Field. Please select the fields you want to use in the calculation, then choose the operations you want to perform, and click "Save" to add your Custom field.
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-sm-6 small">
                Setup your Formula for calculating this Field
            </div>
            <div class="col-sm-6 right-align" data-bind="visible: formulaType()=='build'">
                <a href="#" class="btn btn-secondary btn-sm" data-bind="click: addFormulaParentheses">Add ( )</a>
                <a href="#" class="btn btn-secondary btn-sm" title="Add Today" data-bind="visible: formulaOnlyHasDateFields() || formulaFields().length == 0, click: addFormulaDateToday">Add Today</a>
                <a href="#" class="btn btn-secondary btn-sm" title="Add a Constant Value" data-bind="click: addFormulaConstantValue">Add Value</a>
                <a href="#" class="btn btn-secondary btn-sm" data-bind="click: clearFormulaField">Clear</a>
            </div>
        </div>
        <div class="form-group-row" data-bind="if: formulaOnlyHasDateFields">
            <div class="col-sm-12">
                <div class="alert alert-info">
                    For Dates Field calculation, you can only substract date fields and display the result as days, hours, minutes or seconds.
                </div>
            </div>
        </div>
        <div class="form-group row">
            <label class="col-sm-2 control-label">Field Label</label>
            <div class="col-sm-10">
                <input type="text" class="form-control form-control-sm" data-bind="value: formulaFieldLabel" required placeholder="Custom Field Label" />
            </div>
        </div>
        <div class="form-group row">
            <label class="col-sm-2 control-label">Data Format</label>
            <div class="col-sm-10">
                <select class="form-select form-select-sm" data-bind="value: formulaDataFormat" required>
                    <!-- ko ifnot: formulaOnlyHasDateFields -->
                    <option>String</option>
                    <option>Integer</option>
                    <option>Decimal</option>
                    <option>Currency</option>
                    <!-- /ko -->
                    <!-- ko if: formulaOnlyHasDateFields -->
                    <option>Days</option>
                    <option>Hours</option>
                    <option>Minutes</option>
                    <option>Seconds</option>
                    <!-- /ko -->
                </select>
            </div>
        </div>
        <div class="form-group row" data-bind="visible: formulaDataFormat() == 'Decimal' || formulaDataFormat() == 'Currency'">
            <label class="col-sm-2 control-label">Round to Decimal Places</label>
            <div class="col-sm-10">
                <input type="number" class="form-control" data-bind="value: formulaDecimalPlaces" placeholder="Choose Decimal places (leave blank to not use rounding)" title="Choose Decimal places (leave blank to not use rounding)" />
            </div>
        </div>
        <div class="form-group row" data-bind="visible: appSettings.useSqlCustomField">
            <label class="col-sm-2 control-label">Field Builder Type</label>
            <div class="col-sm-10">
                <select class="form-select form-select-sm" data-bind="value: formulaType" required>
                    <option value="build">Simple Calculation</option>
                    <option value="sql">Advanced Expression</option>
                </select>
            </div>
        </div>

        <div class="form-group row" data-bind="if: formulaType()=='build'">
            <label class="col-sm-2 control-label">Field Formula</label>
            <div class="col-sm-10">
                <div class="text-muted small" data-bind="visible: formulaFields().length == 0">Pick fields to build calculation</div>
                <div class="d-flex align-items-center flex-wrap" data-bind="foreach: formulaFields">
                    <h3 class="me-3" data-bind="visible: setupFormula.isParenthesesStart" style="margin-top: 0;">(</h3>
                    <div data-bind="if: !setupFormula.isParenthesesStart() && !setupFormula.isParenthesesEnd()" class="list-group me-3">
                        <div class="list-group-item d-flex align-items-center formula-field-item" style="margin-left: 15px; padding: 5px 15px">
                            <span data-bind="text: fieldName, visible: !setupFormula.isConstantValue()"></span>
                            <div data-bind="if: setupFormula.isConstantValue" class="d-flex align-items-center">
                                <input data-bind="value: setupFormula.constantValue, visible: setupFormula.constantValue()!='|Today|'" class="form-control form-control-sm me-2" required />
                                <span data-bind="visible: setupFormula.constantValue() == '|Today|'"><b>Today</b></span>
                            </div>
                            <button class="btn btn-danger btn-sm ms-2" data-bind="click: $parent.removeField">
                                <i class="fa fa-trash"></i>
                            </button>
                        </div>
                    </div>
                    <h3 class="me-3" data-bind="visible: setupFormula.isParenthesesEnd" style="margin-top: 0;">)</h3>
                    <div class="me-3" style="margin-left: 15px;" data-bind="visible: $parent.showFormulaOperation($index())">
                        <select class="form-control form-control-sm" style="max-width: 50px;" data-bind="value: setupFormula.formulaOperation">
                            <!-- ko if: !$parent.formulaOnlyHasDateFields() || ($parent.formulaOnlyHasDateFields() && $parent.isConstantOperation($index())) -->
                            <option>+</option>
                            <!-- /ko -->
                            <option>-</option>
                            <!-- ko if: ['Integer','Money','Float','Double','Decimal','Currency'].indexOf($parent.formulaDataFormat()) != -1 -->
                            <option>*</option>
                            <option>/</option>
                            <!-- /ko -->
                        </select>
                    </div>
                </div>

            </div>
        </div>

        <div data-bind="with: customSqlField, visible: formulaType()=='sql'">
            <div class="row">
                <div class="col-md-12">

                    <div class="mb-3">
                        <label class="form-label">Select Data Operation:</label>
                        <select class="form-select" data-bind="select2: {
                            dropdownParent: $root.activeDesign() ? $('#choose-data-design') : $('#choose-data-card'),
                            placeholder: 'Select Function...',
                            data: availableFunctionsGrouped(),
                            templateResult: templateResult
                        }, value: selectedSqlFunction"></select>
                    </div>

                    <div class="mb-3" data-bind="hidden: isConditionalFunction() || selectedSqlFunction() == 'Other'">
                        <label class="form-label">Select the Data Field to use:</label>
                        <select class="form-select"
                                data-bind="select2: {
                                    dropdownParent: $root.activeDesign() ? $('#choose-data-design') : $('#choose-data-card'),
                                    placeholder: 'Search Field...',
                                    ajax: {
                                        url: $parent.textQuery.searchFields.url,
                                        dataType: 'json',
                                        data: $parent.textQuery.searchFields.query,
                                        processResults: $parent.textQuery.searchFields.processResults,
                                        headers: $parent.textQuery.searchFields.headers
                                    },
                                    minimumInputLength: 2,
                                    allowClear: true
                                }, select2Text: selectedField,select2TableId:selectedFieldTableId"></select>
                        <div data-bind="with: selectedField" class="small">
                                Selected: <span class="highlight" data-bind="text: $data"></span>
                        </div>
                    </div>

                    <div class="mb-3" data-bind="if: requiresValue">
                        <label for="inputValue" class="form-label">Provide the relevant value to use:</label>
                        <input type="text" id="inputValue" class="form-control" data-bind="value: inputValue" required />
                    </div>

                    <div class="mb-3" data-bind="visible: selectedSqlFunction() == 'Other'">
                        <label for="custom-sql" class="form-label">Custom SQL Expression:</label>
                        <p class="text-muted">
                            Build your custom SQL Expression below by selecting data fields, adding calculations or using SQL keywords as needed. For string values, remember to enclose them in single quotes ('')
                        </p>
                        <p id="custom-sql" class="hint-input" contenteditable="true" placeholder="Write your custom SQL"></p>
                    </div>
                    <div data-bind="visible: isConditionalFunction">
                        <p class="text-muted">
                            Build your conditional logic below by selecting data fields, adding calculations and defining conditions as needed, and provide corresponding results. For string values, remember to enclose them in single quotes ('')
                        </p>
                        <div class="input-group mb-3">
                            <div class="flex-grow-1">
                                <p class="hint-input" id="condition-field" contenteditable="true" placeholder="Field to compare" title="Field to compare"></p>
                            </div>

                            <div class="mx-2" style="width: 120px;">
                                <select class="form-select form-select-sm" data-bind="options: availableOperators, value: selectedOperator"></select>
                            </div>

                            <div class="flex-grow-1">
                                <p class="hint-input" id="condition-value" contenteditable="true" placeholder="Value to compare" title="Value to compare"></p>
                            </div>

                            <span class="input-group-text" style="max-height: 32px;">THEN</span>

                            <div class="flex-grow-1">
                                <p class="hint-input" id="condition-result" contenteditable="true" placeholder="Condition Result" title="Condition Result"></p>
                            </div>
                        </div>
                        <button class="btn btn-outline-primary" data-bind="click: addOrUpdateCondition,text: editingCondition() ? 'Update Condition' : 'Add Condition'"></button>
                        <ul class="list-group mt-3" data-bind="foreach: conditions">
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <span data-bind="text: conditionDisplay"></span>
                                <button class="btn btn-sm btn-secondary me-1" data-bind="click: $parent.editCondition">Edit</button>
                                <button class="btn btn-sm btn-danger" data-bind="click: $parent.removeCondition">Remove</button>
                            </li>
                        </ul>

                        <div class="input-group mb-3" style="padding-top: 5px;">
                            <span class="input-group-text" style="max-height: 32px;">ELSE</span>
                            <div class="flex-grow-1">
                                <p class="hint-input" id="condition-else" contenteditable="true" placeholder="Default Result" title="Default Result"></p>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <div class="col-md-12">
            <hr />
            <a href="#" class="btn btn-primary btn-sm" title="Save Custom Formula Field" data-bind="click: saveFormulaField, visible: isFormulaField">Save</a>
            <a href="#" class="btn btn-sm" title="Custom Field using Formula" data-bind="click: cancelFormulaField, text: isFormulaField()? 'Cancel': 'Customize', css: {'btn-primary': !isFormulaField(), 'btn-danger': isFormulaField}"></a>
        </div>
    </div>
</script>

<script type="text/html" id="report-designer-compact">
    <div class="designer-container compact-designer" id="choose-data-design" style="font-size:12px;">

      <!-- Visualization Toolbar -->
      <div class="card p-1 mb-2">
         <div class="card-header p-1 d-flex justify-content-between align-items-center">
          <span><i class="fa fa-file"></i> Visualization</span>
          <button id="aiToggleBtn"
                class="btn btn-primary position-fixed bottom-0 end-0 m-3 rounded-circle shadow"
                style="width: 50px; height: 50px; z-index: 1050;"
                title="Chat with AI Assistant"
                data-bind="click: toggleAiChat, visible: appSettings.usePromptBuilder">
            <i class="fa fa-comment fa-lg"></i>
          </button>
          <div>
              <button type="button" class="btn btn-sm btn-outline-secondary me-1" data-bind="click: function() { RunReport(false, true, ReportMode()=='dashboard'); }" title="Re-run Report">
                  <i class="fa fa-play"></i>
              </button>
              <!-- Close for existing reports -->
              <button type="button" class="btn btn-sm btn-outline-secondary" data-bind="visible: ReportID(), click: function() {activeDesign(false); if (isExpanded) isExpanded(false);}" title="Close Designer">
                  <i class="fa fa-times"></i>
              </button>
              <!-- Cancel for new reports -->
              <button type="button" class="btn btn-sm btn-danger" data-bind="visible: !ReportID(), click: function() { if (ReportMode()=='dashboard') $parent.removeNewReport(); else cancelCreateReport(); }" title="Cancel new report">
                  <i class="fa fa-times"></i>
              </button>
          </div>
        </div>
        <div class="card-body p-1" style="overflow-x: auto;">
          <div data-bind="template: 'designer-choose-visual'"></div>
        </div>
      </div>

      <!-- Main Grid -->
      <div class="d-flex flex-row flex-wrap gap-2 compact-filters needs-validation">

        <!-- Data -->
        <div class="card flex-fill expandable-panel" id="dataPanel" style="max-width: 300px"
             data-bind="css:{'collapsed-vertical': panels.isCollapsed('dataPanel')}">
          <div class="card-header p-1" data-bind="click:function(){panels.togglePanel('dataPanel')}">
            <i class="fa fa-database"></i> Data
          </div>

          <div class="card-body p-1">
              <div data-bind="template: 'designer-choose-data'"></div>
          </div>
        </div>

        <!-- Selected -->
        <div class="card flex-fill expandable-panel" id="selectedPanel" style="max-width: 400px"
         data-bind="css:{'collapsed-vertical': panels.isCollapsed('selectedPanel')}">
          <div class="card-header p-1" data-bind="click:function(){panels.togglePanel('selectedPanel')}">
            <i class="fa fa-table"></i> Selected data for the Report
            <a href="#" class="small text-muted float-end"
               data-bind="visible: SelectedFields().length, click:function(){SelectedFields([]);}">Clear all</a>
          </div>

          <div class="card-body designer-auto-update p-1">
                <div style="max-height: 300px; overflow-y: auto;">
                    <div data-bind="template: 'designer-selected-data'"></div>
                </div>
            </div>
        </div>

        <div class="card flex-fill expandable-panel" id="subReportsPanel"
                data-bind="css:{'collapsed-vertical': panels.isCollapsed('subReportsPanel')}, visible: linkedReportFields().length > 0">
            <div class="card-header p-1" data-bind="click:function(){panels.togglePanel('subReportsPanel')}">
            <i class="fa fa-bookmark"></i> Sub Reports
            </div>
            <div class="card-body p-1">
            <div data-bind="template: 'designer-sub-report', data: $data"></div>
            </div>
        </div>

        <div class="card flex-fill expandable-panel" id="htmlReportPanel"
                data-bind="css:{'collapsed-vertical': panels.isCollapsed('htmlReportPanel')}, visible: ReportType()=='Html'">
            <div class="card-header p-1" data-bind="click:function(){panels.togglePanel('htmlReportPanel')}">
            <i class="fa fa-pencil"></i> Custom Design
            </div>
            <div class="card-body p-1">
            <div data-bind="template: 'designer-html', data: $data"></div>
            </div>
        </div>

        <div class="card flex-fill expandable-panel" id="jsonFieldsPanel" data-bind="visible: lastPickedField() && lastPickedField().fieldType == 'Json'">
            <div class="card-body" data-bind="template: 'json-field-picker'"></div>
        </div>

        <!-- Field Options Panel -->
        <div id="fieldOptionsPanel" class="card p-2 mt-2 collapse">
        <!-- dynamic field settings load here -->
        </div>

        <!-- Filters -->
        <div class="card flex-fill expandable-panel" id="filtersPanel"
             data-bind="css:{'collapsed-vertical': panels.isCollapsed('filtersPanel')}">
          <div class="card-header p-1" data-bind="click:function(){panels.togglePanel('filtersPanel')}">
            <i class="fa fa-filter"></i> Filters
          </div>
          <div class="card-body p-1 designer-auto-update" style="max-height:300px; overflow-y:auto;">
            <div data-bind="if:useStoredProc"><div data-bind="template:{name:'filter-parameters'}"></div></div>
            <div data-bind="ifnot:useStoredProc"><div data-bind="template:{name:'filter-group'}"></div></div>
          </div>
        </div>

        <!-- Sort -->
        <div class="card flex-fill expandable-panel" id="sortPanel"
             data-bind="css:{'collapsed-vertical': panels.isCollapsed('sortPanel')}, hidden: useStoredProc()">
          <div class="card-header p-1" data-bind="click:function(){panels.togglePanel('sortPanel')}">
            <i class="fa fa-sort"></i> Sort
          </div>
          <div class="card-body p-1 designer-auto-update row">
            <div data-bind="template: 'designer-sort'"></div>
          </div>
        </div>

        <!-- Settings -->
        <div class="card flex-fill expandable-panel" id="settingsPanel"
             data-bind="css:{'collapsed-vertical': panels.isCollapsed('settingsPanel')}">
          <div class="card-header p-1" data-bind="click:function(){panels.togglePanel('settingsPanel')}">
            <i class="fa fa-gear"></i>Options
          </div>
          <div class="card-body">
            <div class="form-group row">
                <label class="col-form-label h6">
                    <i class="fa fa-file"></i> Report Name
                </label>
                <div>
                    <input type="text" class="form-control" required placeholder="Report Name" data-bind="value: ReportName">
                </div>
            </div>
            <div class="form-group row">
                <label class="control-label h6">
                    <i class="fa fa-info-circle"></i> Report Description
                </label>
                <div>
                    <textarea class="form-control" style="width: 100%;" rows="3" placeholder="Additional details (optional)" data-bind="value: ReportDescription"></textarea>
                </div>
            </div>
            <div class="checkbox" data-bind="visible: CanSaveReports()">
                <label>
                    <input type="checkbox" data-bind="checked: SaveReport">
                    Save Report
                </label>
            </div>
            <div class="form-group row" data-bind="visible: SaveReport">
                <label class="control-label h6">
                    <i class="fa fa-folder-open"></i> Choose Folder
                </label>
                <div>
                    <select class="form-select" style="width: 100%;" data-bind="options: Folders, optionsText: 'FolderName', optionsValue: 'Id', value: FolderID"></select>
                </div>
            </div>
            <hr />
            <div data-bind="template: 'designer-options'"></div>
          </div>
        </div>

        <!-- Schedule -->
        <div class="card flex-fill expandable-panel" id="schedulePanel"
             data-bind="css:{'collapsed-vertical': panels.isCollapsed('schedulePanel')}, visible: SaveReport() && !ko.unwrap(appSettings.showScheduling)">
          <div class="card-header p-1" data-bind="click:function(){panels.togglePanel('schedulePanel')}">
            <i class="fa fa-hourglass"></i> Schedule
          </div>
          <div class="card-body p-1 designer-auto-update row">
            <div data-bind="template: {name: 'report-schedule'}"></div>
          </div>
        </div>

        <!-- Access -->
        <div class="card flex-fill expandable-panel" id="accessPanel"
             data-bind="css:{'collapsed-vertical': panels.isCollapsed('accessPanel')}, visible: adminMode() && !isFormulaField()">
          <div class="card-header p-1" data-bind="click:function(){panels.togglePanel('accessPanel')}">
            <i class="fa fa-key"></i>Security
          </div>

          <div data-bind="" class="card card-body">
            <div data-bind="template: {name: 'manage-access-template', data: manageAccess}"></div>
        </div>
        </div>

      </div>

    </div>
    <hr />
    <!-- AI Assistant Popup -->
    <div id="aiPopup"
         class="position-fixed bottom-0 end-0 m-3 shadow-lg bg-white border rounded-3 d-none d-flex flex-column"
         style="width: 340px; height: 460px; z-index: 1060; overflow: hidden;">

        <div class="d-flex justify-content-between align-items-center border-bottom bg-light p-2 px-3 flex-shrink-0">
            <h6 class="mb-0">
                <i class="fa fa-comments-o me-1"></i> AI Report Assistant
                <span class="alert alert-info" title="This feature is still in Beta release. You can turn it off from settings" style="font-size: 10pt; padding: 5px; max-width: 350px; white-space: normal; margin-bottom: 0;">
                    <i class="fa fa-info-circle"></i> Beta
                </span>
            </h6>
            <div>
                <button class="btn btn-sm btn-outline-secondary me-2" data-bind="click: clearAiChat" title="Clear Chat">
                    <i class="fa fa-trash"></i>
                </button>
                <button class="btn btn-sm btn-outline-secondary" data-bind="click: toggleAiChat" title="Close">
                    <i class="fa fa-times"></i>
                </button>
            </div>
        </div>

        <div id="aiChatBody"
             class="flex-grow-1 overflow-auto p-3"
             style="background: #f8f9fa;">
            <div data-bind="foreach: aiMessages">
            <div class="mb-2" data-bind="css: { 'text-end': role === 'user', 'text-start': role === 'assistant' }">
                <div data-bind="text: content, css: role === 'user' ? 'bg-primary text-white' : 'bg-light border'"
                     class="p-2 rounded-3 d-inline-block"
                     style="max-width: 85%; white-space: pre-wrap;"></div>
            </div>
            </div>
        </div>

        <div class="border-top bg-white p-2 flex-shrink-0">
            <div class="w-100 mb-1 small text-muted">
                💡 Ask things like “Add a column for total orders” or “Show top salesperson this year”
            </div>
            <div class="form-check mb-2">
                <input type="checkbox" class="form-check-input"
                       data-bind="checked: aiAutocompleteDisabled">
                <label class="form-check-label small text-muted">
                    Disable column autocomplete hints
                    <span title="If you disable this, plesae select some data fields in the report designer, choosing data fields to use helps improve results" style="font-size: 10pt; padding: 5px; max-width: 350px; white-space: normal; margin-bottom: 0;">
                        <i class="fa fa-info-circle"></i>
                    </span>
                </label>
            </div>

            <div class="d-flex align-items-center w-100">
                <p id="query-input"
                   class="query-input flex-grow-1 mb-0 p-2 border rounded"
                   contenteditable="true"
                   style="min-height: 38px; overflow-y: auto;"></p>
                <button class="btn btn-primary ms-2"
                        data-bind="click: sendAiMessage">
                    <i class="fa fa-paper-plane"></i>
                </button>
            </div>
        </div>
    </div>

</script>

<script type="text/html" id="report-designer">
    <div class="modal-dialog modal-dialog-scrollable" style="height: 100vh;" id="report-designer-modal">
        <div class="modal-content" style="display: flex; flex-direction: column; height: 100%;">
            <div class="modal-header">
                <h5 class="modal-title" id="myModalLabel">
                    <a title="Need help setting up a report?" target="_blank" href="https://dotnetreport.com/blogs/docs/designing-reports"><span class="fa fa-question-circle"></span></a> Design your Report
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" data-bind="click: onModalCloseClicked" aria-label="Close"></button>
            </div>
            <div class="modal-body needs-validation" style="overflow-y: hidden; flex-grow: 1; display: flex; flex-direction: column;">
               <div class="row flex-grow-1" style="min-height: 0;">
                    <!-- LEFT PANEL -->
                    <div class="col-md-4 h-100" style="overflow-y: auto;">

                        <!-- Live Preview Toggle -->
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <div class="form-check form-switch mb-0">
                                <input class="form-check-input" type="checkbox" role="switch" id="livePreviewSwitch" data-bind="checked: activeDesign">
                                <label class="form-check-label fw-semibold" for="livePreviewSwitch">
                                    <i class="fa fa-bolt text-warning"></i> Live Preview
                                </label>
                            </div>
                            <button class="btn btn-sm btn-outline-primary" data-bind="visible: activeDesign(), click: function() { RunReport(false, true); }" title="Re-run Report">
                                <i class="fa fa-play"></i> Run
                            </button>
                        </div>

                        <!-- ==================== STANDARD MODE (activeDesign OFF) ==================== -->
                        <div data-bind="visible: !activeDesign()">
                            <div class="card card-body" id="choose-data-card" style="min-height: calc(100vh - 200px);">
                                <div class="form-group row align-items-center">
                                    <label class="col-sm-4 col-form-label h6">
                                        <i class="fa fa-file"></i> Report Name
                                    </label>
                                    <div class="col-sm-8">
                                        <input type="text" class="form-control" required placeholder="Report Name" data-bind="value: ReportName">
                                    </div>
                                </div>
                                <hr />
                                <h5><span class="fa fa-database"></span>&nbsp;Choose Data for Report</h5>
                                <div data-bind="template: 'designer-choose-data'"></div>
                            </div>
                            <br />
                            <div class="card card-body">
                                <div class="form-group row">
                                    <label class="control-label h6">
                                        <i class="fa fa-info-circle"></i> Report Description
                                    </label>
                                    <div>
                                        <textarea class="form-control" style="width: 100%;" rows="3" placeholder="Additional details (optional)" data-bind="value: ReportDescription"></textarea>
                                    </div>
                                </div>
                                <div class="checkbox" data-bind="visible: CanSaveReports()">
                                    <label>
                                        <input type="checkbox" data-bind="checked: SaveReport">
                                        Save Report
                                    </label>
                                </div>
                                <div class="form-group row" data-bind="visible: SaveReport">
                                    <label class="control-label h6">
                                        <i class="fa fa-folder-open"></i> Choose Folder
                                    </label>
                                    <div>
                                        <select class="form-select" style="width: 100%;" data-bind="options: Folders, optionsText: 'FolderName', optionsValue: 'Id', value: FolderID"></select>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ==================== LIVE PREVIEW MODE (activeDesign ON) ==================== -->
                        <div data-bind="visible: activeDesign()" class="live-preview-designer" style="font-size: 12px; display: none;">

                            <!-- Data -->
                            <div class="card mb-1 designer-panel">
                                <div class="card-header p-2" data-bind="click: function(){panels.togglePanel('lp-dataPanel')}" style="cursor:pointer;">
                                    <i class="fa fa-database"></i> Data
                                    <i class="fa fa-chevron-down float-end panel-chevron" data-bind="css: {'fa-chevron-right': panels.isCollapsed('lp-dataPanel')}"></i>
                                </div>
                                <div class="card-body p-2" data-bind="visible: !panels.isCollapsed('lp-dataPanel')">
                                    <div class="form-group row align-items-center mb-2">
                                        <label class="col-sm-4 col-form-label"><i class="fa fa-file"></i> Name</label>
                                        <div class="col-sm-8">
                                            <input type="text" class="form-control form-control-sm" required placeholder="Report Name" data-bind="value: ReportName">
                                        </div>
                                    </div>
                                    <div data-bind="template: 'designer-choose-data'"></div>
                                </div>
                            </div>

                            <!-- Visualization -->
                            <div class="card mb-1 designer-panel">
                                <div class="card-header p-2" data-bind="click: function(){panels.togglePanel('lp-vizPanel')}" style="cursor:pointer;">
                                    <i class="fa fa-bar-chart"></i> Visualization
                                    <i class="fa fa-chevron-down float-end panel-chevron" data-bind="css: {'fa-chevron-right': panels.isCollapsed('lp-vizPanel')}"></i>
                                </div>
                                <div class="card-body p-2" data-bind="visible: !panels.isCollapsed('lp-vizPanel')" style="overflow-x: auto;">
                                    <div data-bind="template: 'designer-choose-visual'"></div>
                                </div>
                            </div>

                            <!-- Selected Data -->
                            <div class="card mb-1 designer-panel">
                                <div class="card-header p-2" data-bind="click: function(){panels.togglePanel('lp-selectedPanel')}" style="cursor:pointer;">
                                    <i class="fa fa-table"></i> Selected Data
                                    <a href="#" class="small text-muted float-end me-3" data-bind="visible: SelectedFields().length, click: function(){SelectedFields([]);}">Clear all</a>
                                    <i class="fa fa-chevron-down float-end panel-chevron" data-bind="css: {'fa-chevron-right': panels.isCollapsed('lp-selectedPanel')}"></i>
                                </div>
                                <div class="card-body p-2 designer-auto-update" data-bind="visible: !panels.isCollapsed('lp-selectedPanel')" style="max-height: 300px; overflow-y: auto;">
                                    <div data-bind="template: 'designer-selected-data'"></div>
                                </div>
                            </div>

                            <!-- JSON Field Picker -->
                            <div data-bind="template: 'json-field-picker'"></div>

                            <!-- Sub Reports -->
                            <div class="card mb-1 designer-panel" data-bind="visible: linkedReportFields().length > 0">
                                <div class="card-header p-2" data-bind="click: function(){panels.togglePanel('lp-subReportsPanel')}" style="cursor:pointer;">
                                    <i class="fa fa-bookmark"></i> Sub Reports
                                    <i class="fa fa-chevron-down float-end panel-chevron" data-bind="css: {'fa-chevron-right': panels.isCollapsed('lp-subReportsPanel')}"></i>
                                </div>
                                <div class="card-body p-2" data-bind="visible: !panels.isCollapsed('lp-subReportsPanel')">
                                    <div data-bind="template: 'designer-sub-report'"></div>
                                </div>
                            </div>

                            <!-- HTML Design -->
                            <div class="card mb-1 designer-panel" data-bind="visible: ReportType()=='Html'">
                                <div class="card-header p-2" data-bind="click: function(){panels.togglePanel('lp-htmlPanel')}" style="cursor:pointer;">
                                    <i class="fa fa-pencil"></i> Custom Design
                                    <i class="fa fa-chevron-down float-end panel-chevron" data-bind="css: {'fa-chevron-right': panels.isCollapsed('lp-htmlPanel')}"></i>
                                </div>
                                <div class="card-body p-2" data-bind="visible: !panels.isCollapsed('lp-htmlPanel')">
                                    <div data-bind="template: 'designer-html'"></div>
                                </div>
                            </div>

                            <!-- Filters -->
                            <div class="card mb-1 designer-panel">
                                <div class="card-header p-2" data-bind="click: function(){panels.togglePanel('lp-filtersPanel')}" style="cursor:pointer;">
                                    <i class="fa fa-filter"></i> Filters
                                    <i class="fa fa-chevron-down float-end panel-chevron" data-bind="css: {'fa-chevron-right': panels.isCollapsed('lp-filtersPanel')}"></i>
                                </div>
                                <div class="card-body p-2 designer-auto-update" data-bind="visible: !panels.isCollapsed('lp-filtersPanel')" style="max-height: 300px; overflow-y: auto;">
                                    <div data-bind="visible: useStoredProc"><div data-bind="template: {name: 'filter-parameters'}"></div></div>
                                    <div data-bind="visible: !useStoredProc()"><div data-bind="template: {name: 'filter-group'}"></div></div>
                                    <div class="checkbox">
                                        <label>
                                            <input type="checkbox" data-bind="checked: EditFiltersOnReport" />
                                            Allow setting up and saving filters on Report
                                        </label>
                                    </div>
                                </div>
                            </div>

                            <!-- Sort -->
                            <div class="card mb-1 designer-panel" data-bind="visible: !useStoredProc()">
                                <div class="card-header p-2" data-bind="click: function(){panels.togglePanel('lp-sortPanel')}" style="cursor:pointer;">
                                    <i class="fa fa-sort"></i> Sort
                                    <i class="fa fa-chevron-down float-end panel-chevron" data-bind="css: {'fa-chevron-right': panels.isCollapsed('lp-sortPanel')}"></i>
                                </div>
                                <div class="card-body p-2 designer-auto-update" data-bind="visible: !panels.isCollapsed('lp-sortPanel')">
                                    <div data-bind="template: 'designer-sort'"></div>
                                </div>
                            </div>

                            <!-- Settings & Options -->
                            <div class="card mb-1 designer-panel">
                                <div class="card-header p-2" data-bind="click: function(){panels.togglePanel('lp-settingsPanel')}" style="cursor:pointer;">
                                    <i class="fa fa-gear"></i> Options
                                    <i class="fa fa-chevron-down float-end panel-chevron" data-bind="css: {'fa-chevron-right': panels.isCollapsed('lp-settingsPanel')}"></i>
                                </div>
                                <div class="card-body p-2 designer-options-wrap" data-bind="visible: !panels.isCollapsed('lp-settingsPanel')">
                                    <div class="form-group row mb-2">
                                        <label class="control-label"><i class="fa fa-info-circle"></i> Description</label>
                                        <div>
                                            <textarea class="form-control form-control-sm" rows="2" placeholder="Optional" data-bind="value: ReportDescription"></textarea>
                                        </div>
                                    </div>
                                    <div class="checkbox" data-bind="visible: CanSaveReports()">
                                        <label><input type="checkbox" data-bind="checked: SaveReport"> Save Report</label>
                                    </div>
                                    <div class="form-group row mb-2" data-bind="visible: SaveReport">
                                        <label class="control-label"><i class="fa fa-folder-open"></i> Folder</label>
                                        <div>
                                            <select class="form-select form-select-sm" style="width: 100%;" data-bind="options: Folders, optionsText: 'FolderName', optionsValue: 'Id', value: FolderID"></select>
                                        </div>
                                    </div>
                                    <hr class="my-1" />
                                    <div data-bind="visible: !useStoredProc()">
                                        <div data-bind="template: 'designer-options'"></div>
                                    </div>
                                </div>
                            </div>

                            <!-- Schedule -->
                            <div class="card mb-1 designer-panel" data-bind="visible: SaveReport() && !ko.unwrap(appSettings.showScheduling)">
                                <div class="card-header p-2" data-bind="click: function(){panels.togglePanel('lp-schedulePanel')}" style="cursor:pointer;">
                                    <i class="fa fa-hourglass"></i> Schedule
                                    <i class="fa fa-chevron-down float-end panel-chevron" data-bind="css: {'fa-chevron-right': panels.isCollapsed('lp-schedulePanel')}"></i>
                                </div>
                                <div class="card-body p-2 designer-auto-update" data-bind="visible: !panels.isCollapsed('lp-schedulePanel')">
                                    <div data-bind="template: {name: 'report-schedule'}"></div>
                                </div>
                            </div>

                            <!-- Access -->
                            <div class="card mb-1 designer-panel" data-bind="visible: adminMode()">
                                <div class="card-header p-2" data-bind="click: function(){panels.togglePanel('lp-accessPanel')}" style="cursor:pointer;">
                                    <i class="fa fa-key"></i> Security
                                    <i class="fa fa-chevron-down float-end panel-chevron" data-bind="css: {'fa-chevron-right': panels.isCollapsed('lp-accessPanel')}"></i>
                                </div>
                                <div class="card-body p-2" data-bind="visible: !panels.isCollapsed('lp-accessPanel')">
                                    <div data-bind="template: {name: 'manage-access-template', data: manageAccess}"></div>
                                </div>
                            </div>

                        </div>
                    </div>

                    <!-- RIGHT PANEL -->
                    <div class="col-md-8 h-100" style="overflow-y: auto;">

                        <!-- ==================== STANDARD MODE (activeDesign OFF) ==================== -->
                        <div data-bind="visible: !activeDesign()">
                            <div class="card card-body">
                                <h5><span class="fa fa-file"></span>&nbsp;Choose Visualization</h5>
                                <div style="overflow-x: auto; white-space: nowrap;">
                                    <div data-bind="template: 'designer-choose-visual'"></div>
                                </div>
                            </div>
                            <div id="customFunctionSection" data-bind="visible: isFunctionField() && ReportType() === 'List'" class="custom-field-design">
                                <br />
                                <div class="card">
                                    <div class="card-header"><b>Build Custom Field</b></div>
                                    <div class="card-body" data-bind="template: 'custom-function-designer'"></div>
                                </div>
                                <div class="clearfix"></div>
                            </div>
                            <div data-bind="template: 'json-field-picker'"></div>
                            <div id="customFieldSection" data-bind="visible: isFormulaField" class="custom-field-design">
                                <br />
                                <div class="card">
                                    <div class="card-header"><b>Build Custom Field</b></div>
                                    <div class="card-body" data-bind="template: 'custom-field-designer'"></div>
                                </div>
                                <div class="clearfix"></div>
                            </div>
                            <br />
                            <div class="card card-body">
                                <div class="row">
                                    <h5 class="col-8 pull-left"><span class="fa fa-table"></span>&nbsp;Selected data for the Report</h5>
                                    <div class="col-4 pull-right right-align">
                                        <a href="#" class="small text-muted" data-bind="visible: SelectedFields().length, click: function() {SelectedFields([]);}">Clear all</a>
                                    </div>
                                </div>
                                <div data-bind="template: 'designer-selected-data'"></div>
                            </div>
                            <div data-bind="visible: linkedReportFields().length > 0">
                                <br />
                                <div class="card mb-4">
                                    <div class="card-header bg-light">
                                        <h5 class="mb-0"><i class="fa fa-bookmark"></i> Include Sub Reports</h5>
                                    </div>
                                    <div class="card-body">
                                        <div data-bind="template: 'designer-sub-report'"></div>
                                    </div>
                                </div>
                            </div>
                            <div data-bind="visible: ReportType()=='Html'">
                                <br />
                                <div class="card mb-4">
                                    <div class="card-header bg-light">
                                        <h5 class="mb-0"><i class="fa fa-pencil"></i> Design your Report</h5>
                                    </div>
                                    <div class="card-body">
                                        <div data-bind="template: 'designer-html'"></div>
                                    </div>
                                </div>
                            </div>
                            <br />
                            <div class="card card-body">
                                <h5><span class="fa fa-filter"></span>&nbsp;Choose Filters</h5>
                                <div class="row" style="padding: 10px 10px; overflow-x: auto;">
                                    <div data-bind="visible: useStoredProc" class="col-md-12">
                                        <div data-bind="template: {name: 'filter-parameters'}"></div>
                                    </div>
                                    <div data-bind="visible: !useStoredProc()" class="col-md-12">
                                        <div data-bind="template: {name: 'filter-group'}"></div>
                                    </div>
                                    <div class="checkbox col-12">
                                        <label>
                                            <input type="checkbox" data-bind="checked: EditFiltersOnReport" />
                                            Allow setting up and saving filters on Report
                                        </label>
                                    </div>
                                    <br />
                                </div>
                            </div>
                            <br />
                            <div data-bind="visible: !useStoredProc()" class="card card-body">
                                <h5><span class="fa fa-sort"></span>&nbsp;Choose Sorting</h5>
                                <div data-bind="template: 'designer-sort'"></div>
                            </div>
                            <br />
                            <div data-bind="visible: SaveReport() && !ko.unwrap(appSettings.showScheduling)" class="card card-body">
                                <h5><span class="fa fa-hourglass"></span>&nbsp;Choose Schedule</h5>
                                <div style="padding: 10px 10px" data-bind="visible: SaveReport">
                                    <div data-bind="template: {name: 'report-schedule'}"></div>
                                </div>
                            </div>
                            <br />
                            <div data-bind="visible: !useStoredProc()">
                                <div class="card card-body">
                                    <div data-bind="template: 'designer-options'"></div>
                                </div>
                            </div>
                            <br />
                            <div data-bind="visible: adminMode" class="card card-body">
                                <div data-bind="template: {name: 'manage-access-template', data: manageAccess}"></div>
                            </div>
                        </div>

                        <!-- ==================== LIVE PREVIEW MODE (activeDesign ON) ==================== -->
                        <div data-bind="css: {'d-flex': activeDesign(), 'd-none': !activeDesign()}" class="live-preview-area flex-column" style="height: 100%;">
                            <!-- Custom Field (shown above preview when active) -->
                            <div data-bind="visible: isFormulaField()" class="mb-2">
                                <div class="card custom-field-design">
                                    <div class="card-header py-1"><i class="fa fa-magic"></i> Build Custom Field</div>
                                    <div class="card-body" data-bind="template: 'custom-field-designer'"></div>
                                </div>
                            </div>
                            <!-- Custom Function (shown above preview when active) -->
                            <div data-bind="visible: isFunctionField() && ReportType() === 'List'" class="mb-2">
                                <div class="card custom-field-design">
                                    <div class="card-header py-1"><i class="fa fa-magic"></i> Build Custom Function</div>
                                    <div class="card-body" data-bind="template: 'custom-function-designer'"></div>
                                </div>
                            </div>
                            <div class="card flex-grow-1 d-flex flex-column" style="min-height: 0;">
                                <div class="card-header py-2 d-flex align-items-center justify-content-between bg-light">
                                    <span><i class="fa fa-desktop"></i> Live Preview</span>
                                    <span class="text-muted small" data-bind="visible: ReportName()">
                                        <span data-bind="text: ReportName"></span>
                                    </span>
                                </div>
                                <div class="card-body flex-grow-1" style="overflow-y: auto; min-height: 0;">
                                    <div data-bind="if: typeof CanEdit === 'function' && CanEdit() && ReportType()!='Html' && ReportType()!='Single'">
                                        <div data-bind="template: 'chart-settings', data: $data"></div>
                                    </div>
                                    <div data-bind="if: typeof CanEdit === 'function' && CanEdit() && ReportType()=='Single'">
                                        <div data-bind="template: 'kpi-settings', data: $data"></div>
                                    </div>
                                    <p data-bind="html: ReportDescription, visible: ReportDescription"></p>
                                    <div data-bind="with: ReportResult" class="small">
                                        <div data-bind="visible: !ReportData()">
                                            <div class="report-spinner"></div>
                                        </div>
                                        <div data-bind="template: 'report-template', data: $data"></div>
                                    </div>
                                </div>
                                <div class="card-footer py-1">
                                    <div class="small d-flex align-items-center justify-content-between" data-bind="with: pager">
                                        <div data-bind="visible: totalRecords() > 1 && $parent.ReportType() != 'Single'">
                                            <span data-bind="text: 'Total Records: ' + totalRecords()"></span>
                                        </div>
                                        <div data-bind="visible: pages() > 1 && $parent.ReportType() != 'Single'">
                                            <div data-bind="template: 'pager-template', data: $data"></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-primary" data-bind="visible: adminMode, click: RunReportSqlPreview">
                    <i class="fa fa-code"></i> Preview Report Code
                </button>
                <a href="#" class="btn btn-danger" data-bind="click: cancelCreateReport">Cancel editing Report</a>
                <button class="btn btn-primary" type="button" data-bind="visible: SaveReport() && CanSaveReports(), click: SaveWithoutRun" style="padding-right: 10px;">Save Report</button>
                <button class="btn btn-primary" type="button" data-bind="text: SaveReport() && CanSaveReports()? 'Save & Run Report': 'Run Report', click: SaveAndRunReport">Run Report</button>
            </div>

        </div>
    </div>
</script>

<script type="text/html" id="chart-settings">
    <div class="chart-container pull-right">
        <button class="btn btn-light btn-sm d-flex align-items-center mt-2 chart-settings-btn"
                data-bind="click: toggleChartSettings" title="Report settings">
            <i class="fa fa-cog"></i>
        </button>

        <div class="chart-settings-panel border p-2 shadow-sm bg-light" data-bind="visible: showSettings">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <button class="btn btn-sm btn-close" data-bind="click: toggleChartSettings"></button>
                <h6 class="mb-0">Report Settings</h6>
            </div>
             <ul class="nav nav-tabs nav-sm mb-2 small" data-bind="visible: ReportType() === 'Bar' || ReportType() === 'Pie' || ReportType() === 'Line'">
                <li class="nav-item">
                    <a class="nav-link"
                       data-bs-toggle="tab"
                       data-bind="attr: { href: '#chartTab-' + ReportID() }, css: { active: ReportType() === 'Bar' || ReportType() === 'Pie' || ReportType() === 'Line' }">
                        Chart
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link"
                       data-bs-toggle="tab"
                       data-bind="attr: { href: '#tableTab-' + ReportID() }, css: { active: !(ReportType() === 'Bar' || ReportType() === 'Pie' || ReportType() === 'Line') }">
                        Table
                    </a>
                </li>
            </ul>
            <div class="tab-content small">
                <div class="tab-pane fade"
                     data-bind="attr: { id: 'chartTab-' + ReportID() }, css: { 'show active': ReportType() === 'Bar' || ReportType() === 'Pie' || ReportType() === 'Line' }">
                    <div class="mb-2">
                        <div class="btn-group" role="group" data-bind="visible: ReportType() === 'Bar' || ReportType() === 'Pie' || ReportType() === 'Line'">
                            <button type="button" class="btn btn-light" data-bs-toggle="tooltip" title="Bar Chart"
                                    data-bind="css: { 'active': ReportType() === 'Bar' }, click: function() { ReportType('Bar'); }">
                                <span class="fa fa-bar-chart"></span>
                            </button>
                            <button type="button" class="btn btn-light" data-bs-toggle="tooltip" title="Pie Chart"
                                    data-bind="css: { 'active': ReportType() === 'Pie' }, click: function() { ReportType('Pie'); }">
                                <span class="fa fa-pie-chart"></span>
                            </button>
                            <button type="button" class="btn btn-light" data-bs-toggle="tooltip" title="Line Chart"
                                    data-bind="css: { 'active': ReportType() === 'Line' }, click: function() { ReportType('Line'); }">
                                <span class="fa fa-line-chart"></span>
                            </button>
                        </div>
                    </div>
                    <div data-bind="visible: ReportType()=='Bar'">
                        <div class="form-group row">
                            <div class="checkbox col-6">
                                <label><input type="checkbox" data-bind="checked: barChartHorizontal" /> Horizontal</label>
                            </div>
                            <div class="checkbox col-6">
                                <label><input type="checkbox" data-bind="checked: barChartStacked" /> Stacked</label>
                            </div>
                        </div>
                    </div>
                    <div data-bind="visible: ReportType()=='Pie'">
                        <div class="form-group row">
                            <div class="checkbox col-6">
                                <label><input type="checkbox" data-bind="checked: pieChartDonut" /> Donut</label>
                            </div>
                        </div>
                    </div>
                    <div data-bind="visible: ReportType()=='Line'">
                        <div class="form-group row">
                            <div class="checkbox col-6">
                                <label><input type="checkbox" data-bind="checked: lineChartArea" /> Area</label>
                            </div>
                        </div>
                    </div>
                    <div class="mb-2">
                        <label class="form-label small">Background Color</label>
                        <div class="d-flex align-items-center flex-wrap">
                            <input type="color" class="color-picker" data-bind="value: chartOptions().backgroundColor, attr: { placeholder: 'Select' }, event: { change: updateChart }">
                        </div>
                    </div>
                    <div class="mb-2">
                        <label class="form-label small">Font Color</label>
                        <div class="d-flex align-items-center flex-wrap">
                            <input type="color" class="color-picker" data-bind="value: chartOptions().fontColor, attr: { placeholder: 'Select' }, event: { change: updateChart }">
                        </div>
                    </div>
                    <div class="mb-2">
                        <label class="form-label small">Series Colors</label>
                        <div class="d-flex flex-wrap" data-bind="foreach: chartOptions().seriesColors">
                            <div class="color-box me-2">
                                <input type="color" class="color-picker"
                                       data-bind="value: $data, event: { input: function(data, event) { $parent.updateSeriesColor($index(), event.target.value); } }">
                                <button class="btn btn-sm btn-danger remove-color" data-bind="click: $parent.removeSeriesColor">&times;</button>
                            </div>
                        </div>
                        <button class="color-box btn btn-sm btn-secondary" data-bind="click: addSeriesColor" title="Add Series Color" style="margin-top: -7px;">
                            <i class="fa fa-plus"></i>
                        </button>
                    </div>
                    <div class="d-flex justify-content-between mb-1">
                        <div>
                            <label class="form-label small">Legend Position</label>
                            <select class="form-select form-select-sm" data-bind="value: chartOptions().legendPosition, event: { change: function(data, $event) { updateLegend($event.target.value); } }">
                                <option value="top">Top</option>
                                <option value="right">Right</option>
                                <option value="bottom">Bottom</option>
                                <option value="left">Left</option>
                                <option value="none">None</option>
                            </select>
                        </div>
                        <div>
                            <label class="form-label small">Font Size</label>
                            <input type="number" class="form-control form-control-sm font-size-input" data-bind="value: chartOptions().fontSize, event: { change: updateChart }">
                        </div>
                    </div>
                    <div data-bind="visible: ReportType()!='Pie'">
                        <div class="form-check form-switch small mb-1">
                            <input class="form-check-input" type="checkbox" data-bind="checked: chartOptions().showXAxisLabel, event: { change: updateChart }">
                            <label class="form-check-label">X-Axis Label</label>
                        </div>
                        <div class="form-check form-switch small mb-1">
                            <input class="form-check-input" type="checkbox" data-bind="checked: chartOptions().showYAxisLabel, event: { change: updateChart }">
                            <label class="form-check-label">Y-Axis Label</label>
                        </div>
                        <div class="form-check form-switch small mb-1" data-bind="visible: ReportType() !== 'Pie'">
                            <input class="form-check-input" type="checkbox" data-bind="checked: chartOptions().showGridlines, event: { change: updateChart }">
                            <label class="form-check-label">Gridlines</label>
                        </div>
                        <div class="form-check form-switch small mb-1">
                            <input class="form-check-input" type="checkbox" data-bind="checked: chartOptions().showSmallValuesOnLabel, event: { change: updateChart }">
                            <label class="form-check-label">Show Small Values On Label</label>
                        </div>
                        <div class="form-group small mb-1">
                            <label class="form-label">Y-Axis Format</label>
                            <select class="form-select form-select-sm" data-bind="value: chartOptions().yAxisFormat, event: { change: function() { updateYAxisFormat(); updateChart(); } }">
                                <option value="">Auto (from Field)</option>
                                <option value="Currency">Currency</option>
                                <option value="Percentage">Percentage</option>
                                <option value="Decimal">Decimal</option>
                                <option value="Number">Number</option>
                            </select>
                        </div>
                        <div class="form-group small mb-1 d-flex gap-2">
                            <div class="w-50">
                                <label class="form-label">Y-Axis Min</label>
                                <input type="number" class="form-control form-control-sm" data-bind="value: chartOptions().yMin, event: { change: updateChart }" />
                            </div>
                            <div class="w-50">
                                <label class="form-label">Y-Axis Max</label>
                                <input type="number" class="form-control form-control-sm" data-bind="value: chartOptions().yMax, event: { change: updateChart }" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade"
                     data-bind="attr: { id: 'tableTab-' + ReportID() }, css: { 'show active': !(ReportType() === 'Bar' || ReportType() === 'Pie' || ReportType() === 'Line') }">
                    <div class="form-group row">
                        <div class="mb-2 col-6">
                            <label class="form-label small">Header Back Color</label><br />
                            <input type="color" class="color-picker"
                                   data-bind="attr: { id: 'tbl-color-picker-' + ReportID()} , value: tableSettings().headerBackColor, event: { change: updateTable }"/>
                        </div>
                        <div class="mb-2 col-6">
                            <label class="form-label small">Header Font Color</label><br />
                            <input type="color" class="color-picker"
                                   data-bind="attr: { id: 'tbl-color-picker-' + ReportID()} ,value: tableSettings().headerFontColor, event: { change: updateTable }"/>
                        </div>
                    </div>
                    <div class="form-group row">
                        <div class="mb-2 col-6">
                            <label class="form-label small">Row Back Color</label><br />
                            <input type="color" class="color-picker"
                                   data-bind="attr: { id: 'tbl-color-picker-' + ReportID()} ,value: tableSettings().rowBackColor, event: { change: updateTable }"/>
                        </div>
                        <div class="mb-2 col-6">
                            <label class="form-label small">Row Font Color</label><br />
                            <input type="color" class="color-picker"
                                   data-bind="attr: { id: 'tbl-color-picker-' + ReportID()} ,value: tableSettings().rowFontColor, event: { change: updateTable }"/>
                        </div>
                    </div>
                    <div class="form-group row" style="display: none;">
                        <div class="mb-2 col-6">
                            <label class="form-label small">Alt Row Back Color</label><br />
                            <input type="color" class="color-picker"
                                   data-bind="value: tableSettings().altRowBackColor, event: { change: updateTable }"/>
                        </div>
                        <div class="mb-2 col-6">
                            <label class="form-label small">Alt Row Font Color</label>
                            <input type="color" class="color-picker"
                                   data-bind="value: tableSettings().altRowFontColor, event: { change: updateTable }"/>
                        </div>
                    </div>
                    <div class="form-group mb-2" style="display: none;">
                        <label class="form-label small">Borders</label>
                        <div class="btn-group d-flex flex-wrap">
                            <button type="button" class="btn btn-light btn-sm flex-fill"
                                    data-bind="click: function(){ tableSettings().border('none'); updateTable(); }, css: { active: tableSettings().border === 'none' }">None</button>
                            <button type="button" class="btn btn-light btn-sm flex-fill"
                                    data-bind="click: function(){ tableSettings().border('all'); updateTable(); }, css: { active: tableSettings().border === 'all' }">All</button>
                            <button type="button" class="btn btn-light btn-sm flex-fill"
                                    data-bind="click: function(){ tableSettings().border('outer'); updateTable(); }, css: { active: tableSettings().border === 'outer' }">Outside</button>
                            <button type="button" class="btn btn-light btn-sm flex-fill"
                                    data-bind="click: function(){ tableSettings().border('inner'); updateTable(); }, css: { active: tableSettings().border === 'inner' }">Inside</button>
                        </div>
                    </div>
                    <div class="form-group row">
                        <div class="mb-2 col-6" style="display: none;">
                            <label class="form-label small">Border Color</label>
                            <input type="color" class="color-picker"
                               data-bind="value: tableSettings().borderColor, event: { change: updateTable }"/>
                        </div>
                         <div class="mb-2 col-6">
                            <label class="form-label small">Back Color</label><br />
                            <input type="color" class="color-picker"
                               data-bind="attr: { id: 'tbl-color-picker-' + ReportID()},value: tableSettings().backColor, event: { change: updateTable }"/>
                        </div>
                        <div class="mb-2 col-6 d-flex align-items-end">
                            <button class="btn btn-sm small"
                                    data-bind="click: copyTableFormat"
                                    title="Copy Format">
                                <i class="fa fa-copy"></i>
                            </button>
                            <button class="btn btn-sm small"
                                    data-bind="click: pasteTableFormat"
                                    title="Paste Format">
                                <i class="fa fa-paste"></i>
                            </button>
                            <button class="btn btn-sm small" data-bind="click: clearTableSettings"
                                title="Clear">
                                <i class="fa fa-close"></i>
                            </button>
                        </div>
                    </div>                    
                </div>
            </div>
        </div>
    </div>
</script>

<div class="modal" id="drilldownModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content" data-bind="with: ChartDrillDownData">
            <div class="modal-header">
                <h4 class="modal-title">Drilldown Data</h4>
                <button type="button" class="btn-close pull-right" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <!-- ko if: DrillDownData -->
            <div class="modal-body">
                <div style="overflow-x: auto; max-height: 500px; overflow-y: auto;">
                    <table class="table table-striped table-hover table-condensed" data-bind="with: DrillDownData, attr: {class: 'table table-striped table-hover table-condensed ' + $parent.selectedStyle()}">
                        <thead style="position: sticky; top: -1px; z-index: 2;">
                            <tr class="no-highlight">
                                <!-- ko foreach: Columns -->
                                <th data-bind="attr: { id: fieldId }, css: {'right-align': IsNumeric}, style: {'width': fieldWidth, 'background-color': headerBackColor }, hidden: outerGroup" style="border-right: 1px solid;">
                                    <span data-bind="text: fieldLabel2() ? fieldLabel2() : (fieldLabel() ? fieldLabel() : fieldName), style: {'color': headerFontColor, 'font-weight': headerFontBold() ? 'bold' : 'normal'}"></span>
                                </th>
                                <!-- /ko -->
                            </tr>
                        </thead>
                        <tbody>
                            <tr style="display: none;" data-bind="visible: Rows && Rows.length < 1">
                                <td data-bind="attr:{colspan: Columns.length}">
                                    No records found
                                </td>
                            </tr>
                            <!-- ko foreach: Rows  -->
                            <tr>
                                <!-- ko foreach: Items -->
                                <td data-bind="hidden: outerGroup, style: {'background-color': backColor, 'color': fontColor, 'font-weight': fontBold() ? 'bold' : 'normal' }">
                                    <div data-bind="style: {'width': fieldWidth }">
                                        <!-- ko if: LinkTo-->
                                        <a data-bind="attr: {href: LinkTo}" target="_blank"><span data-bind="html: formattedVal"></span></a>
                                        <!-- /ko-->
                                        <!-- ko ifnot: LinkTo-->
                                        <span data-bind="html: formattedVal"></span>
                                        <!-- /ko-->
                                    </div>
                                </td>
                                <!-- /ko-->
                            </tr>
                            <!-- /ko -->
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <div class="col-xs-12 col-centered" data-bind="with: pager">
                    <div class="form-inline small text-muted">
                        <div class="pull-left total-records" data-bind="visible: pages()">
                            <span data-bind="text: 'Total Records: ' + totalRecords()"></span>
                        </div>
                        <div class="pull-left">
                            <button class="btn btn-xs" title="Download Excel" data-bind="click: $parent.exportExcel"><span class="fa fa-file-excel-o"></span></button>
                            <button class="btn btn-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#sqlDrillDownModal" data-bind="visible: $root.adminMode">
                                <span class="fa fa-code"></span> View Code
                            </button>
                        </div>
                        <div class="form-group pull-right" data-bind="visible: pages()">
                            <div data-bind="template: 'pager-template', data: $data"></div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- /ko -->
        </div>
    </div>
</div>

<div class="modal" id="sqlModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header d-flex justify-content-between align-items-center">
