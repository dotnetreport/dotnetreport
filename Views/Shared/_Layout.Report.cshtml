<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <link rel="shortcut icon" href="/favicon.ico">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Asp .Net Ad Hoc Report Builder - @ViewBag.Title </title>
    <meta name="keywords" content="ad-hoc reporting, reporting, asp .net reporting, asp .net report, report builder, ad hoc report builder, ad-hoc report builder, adhoc report, ad hoc reports, .net report viewer, reportviewer, sql reportviewer, report builder mvc, report mvc, report builder web forms, query builder, sql report builder,visual report builder,custom query,query maker" />
    <meta name="description" content="Ad hoc Reporting software that allows programmers to easily add Reporting functionality to their ASP .NET Web Software Solution" />
    <!-- lucky orange -->
    <script type='text/javascript'>
        window.__lo_site_id = 219451;

        (function () {
            var wa = document.createElement('script'); wa.type = 'text/javascript'; wa.async = true;
            wa.src = 'https://d10lpsik1i8c69.cloudfront.net/w.js';
            var s = document.getElementsByTagName('script')[0]; s.parentNode.insertBefore(wa, s);
        })();

        function showDemoHelp() {
            $("#demoinfoModal").modal('show');
            return false;
        }
    </script>
    
    @Html.Partial("_DotnetReportHeaderPartial")
    @RenderSection("head", required: false)
</head>

<body>
    <link type="text/css" rel="stylesheet" media="all" href="~/Content/themes/default.min.css" id="theme-css" />
    <nav class="navbar navbar-expand-lg navbar-dark sticky-top bg-dark flex-md-nowrap p-0 shadow ">
        <a class="navbar-brand col-md-3 col-lg-2 mr-0 px-3" href="#" id="mainNavImage">
            <img src="~/Content/img/report-logo.png" width="120" />
        </a>
        <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNavDropdown" aria-controls="navbarNavDropdown" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNavDropdown">
            <ul class="navbar-nav mr-auto">
            </ul>
            <ul class="navbar-nav ">
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                        Resources
                    </a>
                    <div class="dropdown-menu" aria-labelledby="navbarDropdown">
                        <a class="dropdown-item" href="https://dotnetreport.com/schedule-demo">Schedule Demo</a>
                        <a class="dropdown-item" href="https://dotnetreport.com/app">Free Trial</a>
                        <a class="dropdown-item" href="https://dotnetreport.com/features">Features</a>
                        <div class="dropdown-divider"></div>

                        <a class="dropdown-item" href="https://www.nuget.org/packages/dotNetReport/" target="_blank"><i class="fa fa-gift"></i> Nuget</a>
                        <a class="dropdown-item" href="https://github.com/dotnetreport" target="_blank"><i class="fa fa-github"></i> Github</a>
                        <a class="dropdown-item" href="https://dotnetreport.com/knowledgebase" target="_blank"><i class="fa fa-book"></i> Knowledgebase</a>
                    </div>
                </li>
            </ul>
        </div>

        <form class="form-inline">
            <button class="btn btn-primary" onclick="return showDemoHelp();">Help with Demo</button>
            <a class="btn btn-primary" href="https://dotnetreport.com/app">Start my Free Trial!</a>
        </form>
    </nav>

    @Html.AntiForgeryToken()
    <div class="container-fluid">
        <div class="row">
            <nav class="col-md-3 col-lg-2 d-md-block sidebar collapse">
                <div class="sidebar-sticky pt-3">
                    <ul class="nav flex-column">
                        <li class="nav-item" id="sidebarMenu">
                            <a class="nav-link" href="@Url.Action("Dashboard","DotNetReport")"><i class='fa fa-fw fa-dashboard'></i> Dashboard</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Index","DotNetReport")"><i class="fa fa-fw fa-file"></i> Reports</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Query","DotNetReport")"><i class="fa fa-fw fa-lightbulb-o"></i> Smart Query (beta)</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-muted"><i class="fa fa-fw fa-user-circle"></i> Customers</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-muted"><i class="fa fa-fw fa-money"></i> Orders</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-muted"><i class="fa fa-fw fa-product-hunt"></i> Products</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-muted"><i class="fa fa-fw fa-user"></i> Profile</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Index","DotnetSetup")"><i class="fa fa-fw fa-gears"></i> Data Configuration (admin only)</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-muted"><i class="fa fa-fw fa-power-off"></i> Log Out</a>
                        </li>
                    </ul>
                </div>
            </nav>

            <main role="main" class="col-md-9 ml-sm-auto col-lg-10 px-md-4">
                <div class="pt-3 pb-2 mb-3">
                    <div id="alertplaceholder"></div>
                    @RenderBody()
                    <br />
                    <br />
                    <br />
                </div>
            </main>
        </div>
    </div>
    <div class="report-layout-footer">
        <!-- ########################## IMPORTANT - PLEASE DO NOT REMOVE WITHOUT PURCHASING LICENSE ########################### -->
        <p>Ad Hoc Reporting and Dashboard powered by <a href="http://www.dotNetReport.com" target="_blank">dotnetreport</a>. Copyright © www.dotnetreport.com.</p>
        <!--########################## IMPORTANT - PLEASE DO NOT REMOVE WITHOUT PURCHASING LICENSE ########################### -->
    </div>

    <div class="modal" id="demoinfoModal" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header" style="display: block; text-align: left;">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                    <h4 class="modal-title">Welcome to the Demo Site!</h4>
                </div>
                <div class="modal-body">
                    <p>The purpose of this Demo Site is to demonstrate how <a href="https://dotnetreport.com">dotnet Report</a> runs embedded inside a Web Application and how end users can run and create useful Reports and Dashboards.</p>
                    <p>The Database this demo site uses has Sales and Products data for a fictional company, with some test Employees, Customers and daily Orders as well. This way, you can run or create test Reports mimicking real world use cases.</p>
                    <p>Feel free to test the <b>Dashboard</b>, run <b>Reports</b> or create new ones using our friendly and intuitive Report Designer. </p>

                    <p class="alert alert-info">Just a warning that any reports or dashboards you create or modify are for testing only and can be reset at any time.</p>

                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-default" data-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    @Html.Partial("_DotnetReportTemplatesPartial")
    @Html.Partial("_DotnetReportJsLibrariesPartial")

    @RenderSection("scripts", required: false)
</body>
</html>
